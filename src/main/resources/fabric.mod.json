{
	"schemaVersion": 1,
	"id": "bunny-lib",
	"version": "${version}",
	"name": "Bunny's Lib",
	"description": "A lightweight dependancy library used for all of Bunny's mods",
	"authors": [
		"BaguetteBunny"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC BY-NC-SA 4.0",
	"icon": "assets/bunny-lib/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"bunny.lib.BunnyLib"
		],
		"modmenu": [
			"bunny.lib.BunnyLibMenu"
		],
		"fabric-datagen": [
			"bunny.lib.BunnyLibDataGenerator"
		],
		"client": [
			"bunny.lib.BunnyLibClient"
		]
	},
	"mixins": [
		"bunny-lib.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.16.14",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*",
		"cloth-config": "*"
	},
	"suggests": {
		"another-mod": "*"
	}
}